<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rental Motor Pro</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root { --primary: #2c3e50; --accent: #e74c3c; }
        body { background: #f8f9fa; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        .navbar { background: var(--primary); color: white; border-bottom: 4px solid var(--accent); }
        .motor-card { border: none; border-radius: 15px; transition: 0.3s; overflow: hidden; }
        .motor-card:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.1); }
        .status-badge { position: absolute; top: 10px; right: 10px; font-size: 0.7rem; }
        .img-container { height: 180px; background: #eee; display: flex; align-items: center; justify-content: center; }
        .price-tag { color: var(--accent); font-weight: bold; font-size: 1.1rem; }
    </style>
</head>
<body>

<nav class="navbar navbar-expand-lg shadow-sm mb-4">
    <div class="container">
        <span class="navbar-brand fw-bold"><i class="fas fa-motorcycle me-2"></i>RENTAL MOTOR PRO</span>
    </div>
</nav>

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h5 class="fw-bold text-secondary">Katalog Unit</h5>
        <button class="btn btn-sm btn-outline-dark" onclick="loadUnit()"><i class="fas fa-sync"></i> Refresh</button>
    </div>

    <div class="row g-3" id="motorGrid">
        <div class="text-center p-5">
            <div class="spinner-border text-primary"></div>
            <p class="mt-2 text-muted">Menghubungkan ke server...</p>
        </div>
    </div>
</div>

<script>
    // GANTI DENGAN URL WEB APP GAS KAMU
    const API_URL = "URL_WEB_APP_APPS_SCRIPT_KAMU";

    async function loadUnit() {
        try {
            const response = await fetch(API_URL + "?action=getMotor");
            const data = await response.json();
            renderGrid(data);
        } catch (err) {
            console.error(err);
            document.getElementById('motorGrid').innerHTML = '<p class="text-center text-danger">Gagal memuat data.</p>';
        }
    }

    function renderGrid(units) {
        const grid = document.getElementById('motorGrid');
        grid.innerHTML = '';
        
        units.forEach(unit => {
            const statusColor = unit.Status === 'Tersedia' ? 'success' : 'danger';
            grid.innerHTML += `
                <div class="col-6 col-md-4 col-lg-3">
                    <div class="card motor-card shadow-sm h-100 position-relative">
                        <span class="badge bg-${statusColor} status-badge">${unit.Status}</span>
                        <div class="img-container">
                            <img src="${unit.FotoURL || 'https://via.placeholder.com/150?text=No+Image'}" class="img-fluid" alt="${unit.Merk}">
                        </div>
                        <div class="card-body p-3">
                            <p class="text-muted small mb-1">${unit.Tipe}</p>
                            <h6 class="card-title fw-bold mb-2">${unit.Merk}</h6>
                            <p class="price-tag mb-3">Rp ${parseInt(unit.HargaPerHari).toLocaleString()}<span class="text-muted small fw-normal">/hari</span></p>
                            <button class="btn btn-dark w-100 btn-sm rounded-pill" ${unit.Status !== 'Tersedia' ? 'disabled' : ''}>
                                ${unit.Status === 'Tersedia' ? 'Sewa Sekarang' : 'Sedang Disewa'}
                            </button>
                        </div>
                    </div>
                </div>
            `;
        });
    }

    window.onload = loadUnit;
</script>
</body>
</html>

